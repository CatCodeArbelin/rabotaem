# Telegram bot token from BotFather.
BOT_TOKEN=

# Telegram Payments provider token from BotFather (for example, YooKassa).
PAYMENT_PROVIDER_TOKEN=

# Optional admin chat ID for order notifications.
ADMIN_CHAT_ID=

# Optional YooKassa receipt/fiscalization settings for provider_data.receipt.
YOOKASSA_RECEIPT_EMAIL=
YOOKASSA_RECEIPT_PHONE=
YOOKASSA_TAX_SYSTEM_CODE=
YOOKASSA_VAT_CODE=1
YOOKASSA_PAYMENT_SUBJECT=commodity
YOOKASSA_PAYMENT_MODE=full_payment
