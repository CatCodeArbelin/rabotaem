# Telegram bot token from BotFather.
BOT_TOKEN=

# Telegram Payments provider token from BotFather -> Payments for this exact bot.
# If Telegram shows "Оплатить (Test)", this is a test token; use a live provider token for real payments.
PAYMENT_PROVIDER_TOKEN=

# Optional admin chat ID for order notifications.
ADMIN_CHAT_ID=

# Optional YooKassa receipt/fiscalization settings for provider_data.receipt.
# Set to true only if the shop fiscalizes receipts through Telegram/YooKassa.
YOOKASSA_SEND_RECEIPT=false
YOOKASSA_RECEIPT_EMAIL=
YOOKASSA_RECEIPT_PHONE=
YOOKASSA_TAX_SYSTEM_CODE=
YOOKASSA_VAT_CODE=1
YOOKASSA_PAYMENT_SUBJECT=commodity
YOOKASSA_PAYMENT_MODE=full_payment
